{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "title": "Synapse",
  "tags": ["matrix", "synapse"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - process_start_time_seconds{job=\"synapse\"}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Resident memory",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes{job=\"synapse\"}",
          "legendFormat": "rss"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU usage",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(process_cpu_seconds_total{job=\"synapse\"}[5m])",
          "legendFormat": "cpu"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP requests received (rate)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(synapse_http_server_requests_received_total{job=\"synapse\"}[5m])) by (method)",
          "legendFormat": "{{method}}"
        }
      ]
    }
  ]
}
