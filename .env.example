# =============================================================================
# Neo — Matrix all-in-one stack configuration
#
# Copy is handled for you: run `./scripts/bootstrap.sh` and it creates .env
# from this file on first run, then fills in every SECRET marked below.
# You only need to edit the "REQUIRED" values before the first run.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — domains
# -----------------------------------------------------------------------------

# Your Matrix identity domain. This becomes user IDs like @alice:example.com and
# is baked into the database on first start. IT CAN NEVER BE CHANGED afterwards.
NEO_SERVER_NAME=example.com

# Public hostname the homeserver is actually reached at (client + federation).
# Federation is delegated here via /.well-known, so this carries everything.
NEO_MATRIX_HOST=matrix.example.com

# Hostnames for the optional web UIs (only used when their profile is enabled).
NEO_ELEMENT_HOST=element.example.com
NEO_ADMIN_HOST=admin.example.com
NEO_GRAFANA_HOST=grafana.example.com

# Hostname clients reach the TURN server at. Give it a DNS-only (grey-cloud)
# record pointing straight at PUBLIC_IP — Cloudflare cannot proxy TURN.
NEO_TURN_HOST=turn.example.com

# Hostname for Matrix Authentication Service (only used with the `mas` profile).
NEO_AUTH_HOST=auth.example.com

# Public IP of this host — REQUIRED for Coturn relay when behind NAT.
# Set to the server's routable IPv4. Only needed if the `coturn` profile is on.
PUBLIC_IP=

# -----------------------------------------------------------------------------
# Components — turn services on/off (comma-separated, no spaces)
#   element     Element Web client
#   admin       Synapse admin UI (Ketesa)
#   coturn      TURN/STUN server for voice/video
#   monitoring  Prometheus + Grafana
#   mas         Matrix Authentication Service (delegated OAuth2 auth). Decide this
#               BEFORE first launch — switching auth modes after users exist is painful.
#   workers     Scale-out: offload outbound federation to a worker process (adds
#               Redis). Helps when in large rooms saturates the single-threaded
#               main process. No reverse-proxy changes.
# Leave empty to run just the core homeserver.
# -----------------------------------------------------------------------------
COMPOSE_PROFILES=element,admin,coturn,monitoring

# -----------------------------------------------------------------------------
# Networking
# -----------------------------------------------------------------------------

# External Docker network that nginx proxy manager already owns. NPM proxies to
# Neo containers by name over this network. Find it with `docker network ls`.
NEO_PROXY_NETWORK=nginxproxymanager_default

# Set true if the apex domain's /.well-known/matrix/ files are served elsewhere
# (e.g. the Cloudflare Worker in cloudflare/) rather than by the neo-wellknown
# container. Bootstrap then skips the apex proxy-host instructions.
NEO_WELLKNOWN_EXTERNAL=false

# Loopback host ports the web services publish, for an nginx proxy manager that
# runs in host-network mode (it can't resolve container names, so it forwards to
# 127.0.0.1:<port>). Bound to 127.0.0.1 — never exposed publicly. Change any that
# collide with something already on the host. If your NPM instead shares a Docker
# network with Neo, you can ignore these and forward to the container names.
NEO_PORT_SYNAPSE=8801
NEO_PORT_MAS=8802
NEO_PORT_ELEMENT=8803
NEO_PORT_ADMIN=8804
NEO_PORT_GRAFANA=8805

# UID/GID the Synapse container runs as. Match the user that owns ./data so the
# bind mounts are writable. Defaults suit a typical single-user host.
NEO_PUID=1000
NEO_PGID=1000

# -----------------------------------------------------------------------------
# Uploads — keep these consistent. NPM's client_max_body_size must be >= this,
# and Cloudflare's free tier hard-caps request bodies at 100 MB regardless.
# -----------------------------------------------------------------------------
SYNAPSE_MAX_UPLOAD_SIZE=50M

# -----------------------------------------------------------------------------
# Image tags — pinned for reproducible deploys. Bump deliberately.
# -----------------------------------------------------------------------------
# Keep reasonably current — Synapse Admin (Ketesa) tracks latest and calls newer
# admin endpoints (e.g. /users/{id}/memberships added in v1.157).
SYNAPSE_IMAGE_TAG=v1.157.0
ELEMENT_IMAGE_TAG=v1.11.109
KETESA_IMAGE_TAG=latest
# MAS GHCR tag has NO leading "v" (e.g. 1.21.0, not v1.21.0).
MAS_IMAGE_TAG=1.21.0
COTURN_IMAGE_TAG=4.6.2
POSTGRES_IMAGE_TAG=16-alpine
PROMETHEUS_IMAGE_TAG=v3.1.0
GRAFANA_IMAGE_TAG=11.4.0
NODE_EXPORTER_IMAGE_TAG=v1.12.1
CADVISOR_IMAGE_TAG=v0.52.1
REDIS_IMAGE_TAG=7-alpine

# -----------------------------------------------------------------------------
# Coturn — VoIP relay (only when the `coturn` profile is enabled)
# -----------------------------------------------------------------------------

# UDP relay port range published on the host. Each concurrent relayed stream
# uses one port; 100 ports comfortably covers a few people in group calls.
COTURN_MIN_PORT=49152
COTURN_MAX_PORT=49251

# TLS for turns:// (port 5349). COTURN_CERT_DIR is a host directory mounted into
# the container at /certs (read-only) — point it at your Let's Encrypt / NPM cert
# store. COTURN_TLS_CERT/KEY are the paths INSIDE the container (under /certs).
# Leave the CERT/KEY blank to run STUN/TURN without TLS. See README for the
# cert-renewal reload note.
COTURN_CERT_DIR=/etc/letsencrypt
COTURN_TLS_CERT=
COTURN_TLS_KEY=

# -----------------------------------------------------------------------------
# SECRETS — leave blank. bootstrap.sh generates and writes these on first run
# and never overwrites an existing value. Do NOT edit by hand once set:
# regenerating them logs everyone out or breaks federation.
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=
SYNAPSE_REGISTRATION_SHARED_SECRET=
SYNAPSE_MACAROON_SECRET=
SYNAPSE_FORM_SECRET=
COTURN_STATIC_AUTH_SECRET=
GRAFANA_ADMIN_PASSWORD=
# Shared secret linking Synapse <-> MAS (only used with the `mas` profile).
MAS_MATRIX_SECRET=
